# Module-level — persiste entre les appels
ont_offline_serial = []
tap_last_offline_time = {}  # tap_id -> timestamp of last offline event


def set_ont_offline(serial):

    def tap_total_off_increment(serial, conn):
        try:
            if serial not in ont_offline_serial:
                command = text(
                    'UPDATE "TAPS" SET total_off = total_off + 1 '
                    'WHERE tap_id = (SELECT tap_id FROM "ONTS" WHERE serial = :serialnum)'
                )
                conn.execute(command, {"serialnum": serial})
                ont_offline_serial.append(serial)
                print(f"Added +1 to total_off for serial: {serial}")
            else:
                pass

        except Exception as e:
            logger.error(f"Error incrementing tap {e}")
            raise

    def tap_outage_off_increment(serial, conn):
        time_window = 30
        try:
            result = conn.execute(
                text(
                    'SELECT t.total_off, t.tap_id FROM "TAPS" t '
                    'JOIN "ONTS" o ON o.tap_id = t.tap_id '
                    'WHERE o.serial = :serialnum'
                ),
                {"serialnum": serial}
            ).fetchone()

            if result is None:
                return

            total_off = result.total_off
            tap_id = result.tap_id
            now = time()

            last = tap_last_offline_time.get(tap_id)
            within_window = last is not None and (now - last) <= time_window

            if total_off >= 2 and within_window:
                conn.execute(
                    text(
                        'UPDATE "TAPS" SET outage_off = outage_off + 1 '
                        'WHERE tap_id = :tap_id'
                    ),
                    {"tap_id": tap_id}
                )
                print(f"Added +1 to outage_off for tap_id: {tap_id}")

            tap_last_offline_time[tap_id] = now

        except Exception as e:
            logger.error(f"Error logging outage_off {e}")
            raise

    try:
        connection = create_engine(f"postgresql://{DB_USER}:{DB_PASS}@{DB_HOST}:{DB_PORT}/{DB_NAME}")
        with connection.connect() as conn:
            statement = text('UPDATE "ONTS" SET is_online = false WHERE serial = :serialnum;')
            conn.execute(statement, {"serialnum": serial})
            tap_total_off_increment(serial, conn)
            tap_outage_off_increment(serial, conn)
            conn.commit()
        print(f"Changed 'is_online' to false for {serial}")
    except Exception as e:
        logger.error(f"Error setting ONT offline: {e}")
        raise


def set_ont_online(serial):

    def tap_total_off_decrement(serial, conn):
        try:
            if serial in ont_offline_serial:
                command = text(
                    'UPDATE "TAPS" SET total_off = total_off - 1 '
                    'WHERE tap_id = (SELECT tap_id FROM "ONTS" WHERE serial = :serialnum)'
                )
                conn.execute(command, {"serialnum": serial})
                ont_offline_serial.remove(serial)
                print(f"ONT came back online with serial number: {serial}")
            else:
                pass

        except Exception as e:
            logger.error(f"Error updating {e}")
            raise

    def tap_outage_off_decrement(serial, conn):
        time_window = 30
        try:
            result = conn.execute(
                text(
                    'SELECT t.total_off, t.tap_id FROM "TAPS" t '
                    'JOIN "ONTS" o ON o.tap_id = t.tap_id '
                    'WHERE o.serial = :serialnum'
                ),
                {"serialnum": serial}
            ).fetchone()

            if result is None:
                return

            total_off = result.total_off
            tap_id = result.tap_id
            now = time()

            last = tap_last_offline_time.get(tap_id)
            within_window = last is not None and (now - last) <= time_window

            if total_off <= 2 and within_window:
                conn.execute(
                    text(
                        'UPDATE "TAPS" SET outage_off = outage_off - 1 '
                        'WHERE tap_id = :tap_id'
                    ),
                    {"tap_id": tap_id}
                )
                print(f"Subtracted -1 from outage_off for tap_id: {tap_id}")

        except Exception as e:
            logger.error(f"Error logging outage_off {e}")
            raise

    try:
        connection = create_engine(f"postgresql://{DB_USER}:{DB_PASS}@{DB_HOST}:{DB_PORT}/{DB_NAME}")
        with connection.connect() as conn:
            statement = text('UPDATE "ONTS" SET is_online = true WHERE serial = :serialnum;')
            conn.execute(statement, {"serialnum": serial})
            tap_outage_off_decrement(serial, conn)
            tap_total_off_decrement(serial, conn)
            conn.commit()
        print(f"Changed 'is_online' to true for {serial}")
    except Exception as e:
        logger.error(f"Error setting ONT online: {e}")
        raise