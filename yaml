apiVersion: apps/v1
kind: Deployment
metadata:
  name: fastapi-webhook
  namespace: messaging
spec:
  replicas: 3
  selector:
    matchLabels:
      app: fastapi-webhook
  template:
    metadata:
      labels:
        app: fastapi-webhook
    spec:
      containers:
        - name: fastapi-webhook
          image: 10.241.6.185:5000/fastapi-webhook:latest
          imagePullPolicy: Always
          ports:
            - containerPort: 8000
          env:
            - name: RABBITMQ_HOST
              value: "zabbix-mq.messaging.svc.cluster.local"
            - name: RABBITMQ_PORT
              value: "5672"
            - name: RABBITMQ_USER
              value: "kubadmin"
            - name: RABBITMQ_PASS
              valueFrom:
                secretKeyRef:
                  name: rabbitmq-secret
                  key: password
            - name: RABBITMQ_VHOST
              value: "zabbix_alerts"
---
apiVersion: v1
kind: Service
metadata:
  name: fastapi-webhook-svc
  namespace: messaging
spec:
  type: NodePort
  selector:
    app: fastapi-webhook
  ports:
    - port: 8000
      targetPort: 8000
      nodePort: 30800